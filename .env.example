# ============================================================
# sber26-bot — environment variables
# Copy to `.env` for local dev. On Railway — add as Variables.
# ============================================================

# ---- Core ----
# Environment: dev | prod
APP_ENV=dev
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Telegram ----
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_ME

# Main group chat id (negative number for groups). Get it by adding the bot
# to the chat and running /chatid — the bot will print the current chat id.
MAIN_CHAT_ID=-1001234567890

# Comma-separated Telegram user ids allowed to interact with the bot.
# Pre-filled with Казах + Арбуз. Add assistants here if/when they join.
ALLOWED_TG_USER_IDS=6885525649,7220305943

# Owner (Казах) — only this user can /undo others' operations.
OWNER_TG_USER_ID=6885525649

# ---- Anthropic ----
# Get a key at https://console.anthropic.com (NOT the Max subscription).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5

# ---- Database ----
# Locally: postgres running on localhost.
# On Railway: this var is injected automatically when you attach a Postgres
# service to the bot service — do NOT set it manually there.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sber26

# ---- Observability (optional for MVP; leave empty) ----
SENTRY_DSN=

# ---- Feature flags ----
ENABLE_PRANKS=false
# Relaxed reaction mode: bot parses non-@messages for obvious patterns too.
HYBRID_LISTEN_MODE=true
